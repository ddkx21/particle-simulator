# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# Virtual environment
.venv/

# Results & data (keep directories, ignore contents)
results/*
!results/.gitkeep
!results/plots/
results/plots/*
!results/plots/.gitkeep
!results/euler_error/
results/euler_error/*
!results/euler_error/.gitkeep

