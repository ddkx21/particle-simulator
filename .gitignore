benchmarks/plots/*
!benchmarks/plots/.gitkeep

# Statistics output (generated)
statistics/results/*
statistics/plots/*
!statistics/results/.gitkeep
!statistics/plots/.gitkeep

# Large data files
*.npz
*.xlsx
*.prof
*.csv

# Images (generated)
*.png
*.gif

