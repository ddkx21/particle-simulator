# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# Test / benchmark caches
.pytest_cache/
.benchmarks/
.coverage
.coverage.*
htmlcov/
coverage.xml
junit-*.xml
.mypy_cache/
.ruff_cache/

# Virtual environment
.venv/
venv/
env/

# Results & data (keep directories, ignore contents)
results/*
!results/.gitkeep
!results/plots/
results/plots/*
!results/plots/.gitkeep
!results/euler_error/
results/euler_error/*
!results/euler_error/.gitkeep
!results/boundary_benchmark/
results/boundary_benchmark/*
!results/boundary_benchmark/.gitkeep
!results/boundary_benchmark/plots/
results/boundary_benchmark/plots/*
!results/boundary_benchmark/plots/.gitkeep

# Convergence test results (generated)
convergence_test/results/*
!convergence_test/results/.gitkeep

# Benchmark plots (generated)
benchmarks/plots/*
!benchmarks/plots/.gitkeep

# Statistics output (generated)
statistics/results/*
statistics/plots/*
!statistics/results/.gitkeep
!statistics/plots/.gitkeep

# Large data files
*.npz
*.xlsx
*.prof
*.csv

# Images (generated)
*.png
*.gif

# Но не игнорируем медиа для README в .github/assets/
!.github/assets/**/*.png
!.github/assets/**/*.gif
!.github/assets/**/*.jpg
!.github/assets/**/*.jpeg
!.github/assets/**/*.svg
!.github/assets/**/*.webp

# Obsidian
.obsidian/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# DOCS
docs/
